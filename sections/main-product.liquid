<section class="wf-section">
  <div class="wf-wrap">
    <div class="wf-grid wf-product-hero">
      <div class="wf-tile">
        {% if product.images.size > 0 %}
          <div class="wf-product-gallery" data-wf-product-gallery>
            {%- assign stage_image = product.images.first -%}
            <button type="button" class="wf-product-gallery__stage-btn" data-gallery-open aria-label="Open product image zoom view">
              <img
                src="{{ stage_image | image_url: width: 1800 }}"
                alt="{{ stage_image.alt | default: product.title | escape }}"
                class="wf-product-gallery__stage-image"
                data-gallery-stage
                data-gallery-index="0"
                loading="lazy">
            </button>

            {% if product.images.size > 1 %}
              <div class="wf-product-gallery__thumbs" role="list" aria-label="Product image thumbnails">
                {% for image in product.images %}
                  <button
                    type="button"
                    class="wf-product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
                    data-gallery-thumb
                    data-gallery-index="{{ forloop.index0 }}"
                    data-gallery-src="{{ image | image_url: width: 1800 }}"
                    data-gallery-alt="{{ image.alt | default: product.title | escape }}"
                    aria-label="Show image {{ forloop.index }} of {{ product.images.size }}">
                    <img
                      src="{{ image | image_url: width: 240 }}"
                      alt="{{ image.alt | default: product.title | escape }}"
                      class="wf-product-gallery__thumb-image"
                      loading="lazy">
                  </button>
                {% endfor %}
              </div>
            {% endif %}

            <div class="wf-product-gallery__modal" data-gallery-modal hidden>
              <button type="button" class="wf-product-gallery__close" data-gallery-close aria-label="Close image zoom">Close</button>
              <div class="wf-product-gallery__modal-frame">
                <img src="{{ stage_image | image_url: width: 2400 }}" alt="{{ stage_image.alt | default: product.title | escape }}" class="wf-product-gallery__modal-image" data-gallery-modal-image>
              </div>
            </div>
          </div>
        {% endif %}

        {% if product.description != blank %}
          <div class="wf-product-hero__description">{{ product.description }}</div>
        {% endif %}
      </div>

      <div class="wf-tile wf-product-hero__aside">
        <h1 class="wf-product-hero__title">{{ product.title }}</h1>

        <p class="wf-product-hero__price">{{ product.price | money }}</p>

        {% assign short_description = product.description | strip_html | strip_newlines | truncate: 140 %}
        {% if short_description != blank %}
          <p class="wf-product-hero__short">{{ short_description }}</p>
        {% endif %}

        {% if product.available and product.selected_or_first_available_variant %}
          {% form 'product', product %}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            <button class="wf-btn wf-btn--primary wf-product-hero__cart-btn" type="submit">Add to cart</button>
          {% endform %}
        {% else %}
          <div class="wf-product-hero__option-note">Currently unavailable.</div>
        {% endif %}

        <a class="wf-btn wf-product-hero__cart-link" href="{{ routes.cart_url }}">Go to cart</a>

        <ul class="wf-trust-strip" aria-label="Wellfino trust standards">
          <li>&#10003; Packaged in the USA</li>
          <li>&#10003; Manufactured in FDA-Registered Facilities</li>
          <li>&#10003; GMP-Certified Production</li>
          <li>&#10003; Third-Party Tested for Quality</li>
        </ul>
      </div>
    </div>
  </div>
</section>

{% assign debug_stacks = false %}
{% if request.query_string != blank and request.query_string contains 'debug_stacks=1' %}
  {% assign debug_stacks = true %}
{% endif %}
{% assign associated_stacks_list = product.metafields.custom.associated_stacks.value | default: product.metafields.custom.associated_stacks %}
{% assign stack_options_list = product.metafields.custom.stack_options.value | default: product.metafields.custom.stack_options %}
{% assign associated_stack_single = product.metafields.custom.associated_stack.value | default: product.metafields.custom.associated_stack %}
{% assign rendered_stack_handles = '|' %}
{% assign related_stack_count = 0 %}
{% assign metafield_stack_count = 0 %}
{% assign tag_stack_count = 0 %}
{% assign collection_stack_count = 0 %}
{% assign matched_stack_tags = '' %}
{% assign product_collection_handles = '' %}
{% assign stack_cards_markup = '' %}

{% if associated_stacks_list != blank %}
  {% for stack_product in associated_stacks_list %}
    {% if stack_product != blank and stack_product.url != blank and stack_product.id != product.id %}
      {% capture stack_token %}|{{ stack_product.handle }}|{% endcapture %}
      {% unless rendered_stack_handles contains stack_token %}
        {% assign rendered_stack_handles = rendered_stack_handles | append: stack_product.handle | append: '|' %}
        {% assign related_stack_count = related_stack_count | plus: 1 %}
        {% assign metafield_stack_count = metafield_stack_count | plus: 1 %}
        {% capture stack_cards_markup %}{{ stack_cards_markup }}
          <a class="wf-product-card" href="{{ stack_product.url }}">
            <div class="wf-product-card__media">
              {% if stack_product.featured_image %}
                <img class="wf-product-card__img wf-product-card__img--stack" src="{{ stack_product.featured_image | image_url: width: 720 }}" alt="{{ stack_product.featured_image.alt | default: stack_product.title | escape }}" loading="lazy">
              {% else %}
                <div class="wf-product-card__img wf-product-card__img--placeholder" aria-hidden="true">No Image</div>
              {% endif %}
              <span class="wf-product-card__price">{{ stack_product.price | money }}</span>
            </div>
            <div class="wf-product-card__content">
              <h3>{{ stack_product.title }}</h3>
              <span class="wf-product-card__view">View &rarr;</span>
            </div>
          </a>
        {% endcapture %}
      {% endunless %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if stack_options_list != blank %}
  {% for stack_product in stack_options_list %}
    {% if stack_product != blank and stack_product.url != blank and stack_product.id != product.id %}
      {% capture stack_token %}|{{ stack_product.handle }}|{% endcapture %}
      {% unless rendered_stack_handles contains stack_token %}
        {% assign rendered_stack_handles = rendered_stack_handles | append: stack_product.handle | append: '|' %}
        {% assign related_stack_count = related_stack_count | plus: 1 %}
        {% assign metafield_stack_count = metafield_stack_count | plus: 1 %}
        {% capture stack_cards_markup %}{{ stack_cards_markup }}
          <a class="wf-product-card" href="{{ stack_product.url }}">
            <div class="wf-product-card__media">
              {% if stack_product.featured_image %}
                <img class="wf-product-card__img wf-product-card__img--stack" src="{{ stack_product.featured_image | image_url: width: 720 }}" alt="{{ stack_product.featured_image.alt | default: stack_product.title | escape }}" loading="lazy">
              {% else %}
                <div class="wf-product-card__img wf-product-card__img--placeholder" aria-hidden="true">No Image</div>
              {% endif %}
              <span class="wf-product-card__price">{{ stack_product.price | money }}</span>
            </div>
            <div class="wf-product-card__content">
              <h3>{{ stack_product.title }}</h3>
              <span class="wf-product-card__view">View &rarr;</span>
            </div>
          </a>
        {% endcapture %}
      {% endunless %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if associated_stack_single != blank and associated_stack_single.url != blank and associated_stack_single.id != product.id %}
  {% capture stack_token %}|{{ associated_stack_single.handle }}|{% endcapture %}
  {% unless rendered_stack_handles contains stack_token %}
    {% assign rendered_stack_handles = rendered_stack_handles | append: associated_stack_single.handle | append: '|' %}
    {% assign related_stack_count = related_stack_count | plus: 1 %}
    {% assign metafield_stack_count = metafield_stack_count | plus: 1 %}
    {% capture stack_cards_markup %}{{ stack_cards_markup }}
      <a class="wf-product-card" href="{{ associated_stack_single.url }}">
        <div class="wf-product-card__media">
          {% if associated_stack_single.featured_image %}
            <img class="wf-product-card__img wf-product-card__img--stack" src="{{ associated_stack_single.featured_image | image_url: width: 720 }}" alt="{{ associated_stack_single.featured_image.alt | default: associated_stack_single.title | escape }}" loading="lazy">
          {% else %}
            <div class="wf-product-card__img wf-product-card__img--placeholder" aria-hidden="true">No Image</div>
          {% endif %}
          <span class="wf-product-card__price">{{ associated_stack_single.price | money }}</span>
        </div>
        <div class="wf-product-card__content">
          <h3>{{ associated_stack_single.title }}</h3>
          <span class="wf-product-card__view">View &rarr;</span>
        </div>
      </a>
    {% endcapture %}
  {% endunless %}
{% endif %}

{% for tag in product.tags %}
  {% assign tag_down = tag | downcase %}
  {% if tag_down contains 'stack:' %}
    {% assign stack_handle = tag_down | remove: 'stack:' | strip %}
    {% assign stack_product_by_tag = all_products[stack_handle] %}
    {% if matched_stack_tags == blank %}
      {% assign matched_stack_tags = tag %}
    {% else %}
      {% assign matched_stack_tags = matched_stack_tags | append: ', ' | append: tag %}
    {% endif %}
    {% if stack_product_by_tag != blank and stack_product_by_tag.url != blank and stack_product_by_tag.id != product.id %}
      {% capture stack_token %}|{{ stack_product_by_tag.handle }}|{% endcapture %}
      {% unless rendered_stack_handles contains stack_token %}
        {% assign rendered_stack_handles = rendered_stack_handles | append: stack_product_by_tag.handle | append: '|' %}
        {% assign related_stack_count = related_stack_count | plus: 1 %}
        {% assign tag_stack_count = tag_stack_count | plus: 1 %}
        {% capture stack_cards_markup %}{{ stack_cards_markup }}
          <a class="wf-product-card" href="{{ stack_product_by_tag.url }}">
            <div class="wf-product-card__media">
              {% if stack_product_by_tag.featured_image %}
                <img class="wf-product-card__img wf-product-card__img--stack" src="{{ stack_product_by_tag.featured_image | image_url: width: 720 }}" alt="{{ stack_product_by_tag.featured_image.alt | default: stack_product_by_tag.title | escape }}" loading="lazy">
              {% else %}
                <div class="wf-product-card__img wf-product-card__img--placeholder" aria-hidden="true">No Image</div>
              {% endif %}
              <span class="wf-product-card__price">{{ stack_product_by_tag.price | money }}</span>
            </div>
            <div class="wf-product-card__content">
              <h3>{{ stack_product_by_tag.title }}</h3>
              <span class="wf-product-card__view">View &rarr;</span>
            </div>
          </a>
        {% endcapture %}
      {% endunless %}
    {% endif %}
  {% endif %}
{% endfor %}

{% for rel_collection in product.collections %}
  {% if product_collection_handles == blank %}
    {% assign product_collection_handles = rel_collection.handle %}
  {% else %}
    {% assign product_collection_handles = product_collection_handles | append: ', ' | append: rel_collection.handle %}
  {% endif %}
  {% for collection_product in rel_collection.products limit: 50 %}
    {% if collection_product.id != product.id %}
      {% assign collection_product_type_down = collection_product.type | downcase %}
      {% assign collection_product_tags_down = collection_product.tags | join: ',' | downcase %}
      {% assign collection_product_handle_down = collection_product.handle | downcase %}
      {% assign collection_product_is_stack = false %}
      {% if collection_product_type_down contains 'stack' or collection_product_tags_down contains 'stack' or collection_product_handle_down contains 'stack' %}
        {% assign collection_product_is_stack = true %}
      {% endif %}
      {% if collection_product_is_stack %}
        {% capture stack_token %}|{{ collection_product.handle }}|{% endcapture %}
        {% unless rendered_stack_handles contains stack_token %}
          {% assign rendered_stack_handles = rendered_stack_handles | append: collection_product.handle | append: '|' %}
          {% assign related_stack_count = related_stack_count | plus: 1 %}
          {% assign collection_stack_count = collection_stack_count | plus: 1 %}
          {% capture stack_cards_markup %}{{ stack_cards_markup }}
            <a class="wf-product-card" href="{{ collection_product.url }}">
              <div class="wf-product-card__media">
                {% if collection_product.featured_image %}
                  <img class="wf-product-card__img wf-product-card__img--stack" src="{{ collection_product.featured_image | image_url: width: 720 }}" alt="{{ collection_product.featured_image.alt | default: collection_product.title | escape }}" loading="lazy">
                {% else %}
                  <div class="wf-product-card__img wf-product-card__img--placeholder" aria-hidden="true">No Image</div>
                {% endif %}
                <span class="wf-product-card__price">{{ collection_product.price | money }}</span>
              </div>
              <div class="wf-product-card__content">
                <h3>{{ collection_product.title }}</h3>
                <span class="wf-product-card__view">View &rarr;</span>
              </div>
            </a>
          {% endcapture %}
        {% endunless %}
      {% endif %}
    {% endif %}
  {% endfor %}
{% endfor %}

{% if related_stack_count > 0 or debug_stacks %}
  <section id="stack-options" class="wf-section">
    <div class="wf-wrap">
      <div class="wf-section__head">
        <h2 class="wf-section__title">Stack Options</h2>
      </div>
      <div class="wf-tile">
        {% if related_stack_count > 0 %}
          <p class="wf-page-intro">Available in these stacks:</p>
          <div class="wf-grid wf-product-grid">
            {{ stack_cards_markup }}
          </div>
        {% elsif debug_stacks %}
          <p class="wf-page-intro">0 stacks found.</p>
        {% endif %}

        {% if debug_stacks %}
          <div class="wf-product-hero__option-note" style="margin-top:10px;">
            <strong>Debug stack discovery</strong><br>
            associated_stacks present: {% if associated_stacks_list != blank %}yes{% else %}no{% endif %}<br>
            stack_options present: {% if stack_options_list != blank %}yes{% else %}no{% endif %}<br>
            associated_stack present: {% if associated_stack_single != blank %}yes{% else %}no{% endif %}<br>
            matched stack tags: {% if matched_stack_tags != blank %}{{ matched_stack_tags }}{% else %}none{% endif %}<br>
            product collections: {% if product_collection_handles != blank %}{{ product_collection_handles }}{% else %}none{% endif %}<br>
            found via metafields: {{ metafield_stack_count }}<br>
            found via tags: {{ tag_stack_count }}<br>
            found via collections: {{ collection_stack_count }}<br>
            total related stacks: {{ related_stack_count }}
          </div>
        {% endif %}
      </div>
    </div>
  </section>
{% endif %}

<script>
  (function() {
    function initProductGallery() {
      var galleries = document.querySelectorAll("[data-wf-product-gallery]");
      galleries.forEach(function(gallery) {
        if (gallery.dataset.enhanced === "true") return;
        gallery.dataset.enhanced = "true";

        var stageImage = gallery.querySelector("[data-gallery-stage]");
        var thumbs = gallery.querySelectorAll("[data-gallery-thumb]");
        var openButton = gallery.querySelector("[data-gallery-open]");
        var modal = gallery.querySelector("[data-gallery-modal]");
        var modalImage = gallery.querySelector("[data-gallery-modal-image]");
        var closeButtons = gallery.querySelectorAll("[data-gallery-close]");

        function setActiveImage(src, alt, index) {
          if (!stageImage || !src) return;
          stageImage.setAttribute("src", src);
          stageImage.setAttribute("alt", alt || "");
          stageImage.setAttribute("data-gallery-index", String(index || 0));
          if (modalImage) {
            modalImage.setAttribute("src", src);
            modalImage.setAttribute("alt", alt || "");
          }
          thumbs.forEach(function(thumb) {
            thumb.classList.toggle("is-active", thumb.getAttribute("data-gallery-index") === String(index || 0));
          });
        }

        thumbs.forEach(function(thumb) {
          thumb.addEventListener("click", function() {
            setActiveImage(
              thumb.getAttribute("data-gallery-src"),
              thumb.getAttribute("data-gallery-alt"),
              thumb.getAttribute("data-gallery-index")
            );
          });
        });

        function closeModal() {
          if (!modal) return;
          modal.setAttribute("hidden", "");
          document.body.classList.remove("wf-modal-open");
        }

        function openModal() {
          if (!modal || !stageImage) return;
          if (modalImage) {
            modalImage.setAttribute("src", stageImage.getAttribute("src") || "");
            modalImage.setAttribute("alt", stageImage.getAttribute("alt") || "");
          }
          modal.removeAttribute("hidden");
          document.body.classList.add("wf-modal-open");
        }

        if (openButton) {
          openButton.addEventListener("click", openModal);
        }

        closeButtons.forEach(function(button) {
          button.addEventListener("click", closeModal);
        });

        if (modal) {
          modal.addEventListener("click", function(event) {
            if (event.target === modal) closeModal();
          });
        }

        document.addEventListener("keydown", function(event) {
          if (event.key === "Escape" && modal && !modal.hasAttribute("hidden")) {
            closeModal();
          }
        });
      });
    }

    initProductGallery();

    window.addEventListener("load", function() {
      initProductGallery();
    });
  })();
</script>

{% schema %}
{
  "name": "Main product",
  "settings": []
}
{% endschema %}
