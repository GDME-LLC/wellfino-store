{% if associated_stacks_raw != blank and associated_stacks_raw.url != blank and associated_stacks_raw.id != product.id %}
  {% capture token %}|{{ associated_stacks_raw.handle }}|{% endcapture %}
  {% unless rendered_stack_handles contains token %}
    {% assign rendered_stack_handles = rendered_stack_handles | append: associated_stacks_raw.handle | append: '|' %}
    {% assign related_stack_count = related_stack_count | plus: 1 %}
    {% assign metafield_stack_count = metafield_stack_count | plus: 1 %}
    {% capture stack_cards_markup %}{{ stack_cards_markup }}
      <a class="wf-product-card" href="{{ associated_stacks_raw.url }}">
        <div class="wf-product-card__media">
          {% if associated_stacks_raw.featured_image %}
            <img class="wf-product-card__img wf-product-card__img--stack" src="{{ associated_stacks_raw.featured_image | image_url: width: 720 }}" alt="{{ associated_stacks_raw.featured_image.alt | default: associated_stacks_raw.title | escape }}" loading="lazy">
          {% else %}
            <div class="wf-product-card__img wf-product-card__img--placeholder" aria-hidden="true">No Image</div>
          {% endif %}
          <span class="wf-product-card__price">{{ associated_stacks_raw.price | money }}</span>
        </div>
        <div class="wf-product-card__content">
          <h3>{{ associated_stacks_raw.title }}</h3>
          <span class="wf-product-card__view">View &rarr;</span>
        </div>
      </a>
    {% endcapture %}
  {% endunless %}
{% endif %}
{% if associated_stacks_raw != blank %}
  {% for stack_product in associated_stacks_raw %}
    {% if stack_product != blank and stack_product.url != blank and stack_product.id != product.id %}
      {% capture token %}|{{ stack_product.handle }}|{% endcapture %}
      {% unless rendered_stack_handles contains token %}
