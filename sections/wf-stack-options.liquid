          </a>
        {% endcapture %}
      {% endunless %}
    {% endif %}
  {% endfor %}
{% endif %}
{% assign associated_stacks_text = associated_stacks_raw | append: '' | downcase | replace: ' ', '' | replace: '|', ',' | replace: ';', ',' %}
{% if associated_stacks_text contains '/products/' %}
  {% assign associated_stacks_text = associated_stacks_text | replace: '/products/', '' %}
{% endif %}
{% for stack_handle in associated_stacks_text | split: ',' %}
