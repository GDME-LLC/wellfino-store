{% assign related_stack_count = 0 %}
{% assign metafield_stack_count = 0 %}
{% assign tag_stack_count = 0 %}
{% assign collection_stack_count = 0 %}
{% assign matched_stack_tags = '' %}
{% assign collection_handles = '' %}
